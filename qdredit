def get_embedding(text, url):
    """Send text to embedding server and return vector.
    Supports both OpenAI-compatible (data[0].embedding) and Harrier-style (embeddings[0]).
    """
    resp = requests.post(url, json={"input": [text]})
    if resp.status_code != 200:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} Embedding server error: {resp.status_code} - {resp.text}", file=sys.stderr)
        return None
    data = resp.json()
    # Try OpenAI format first (llama.cpp)
    if "data" in data and len(data["data"]) > 0:
        return data["data"][0].get("embedding")
    # Fallback to older Harrier format
    embeddings = data.get("embeddings", [])
    if embeddings:
        return embeddings[0]
    print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} Unexpected embedding response format: {data}", file=sys.stderr)
    return None

def get_next_integer_id(collection):
    points = get_all_points(collection)
    int_ids = [p["id"] for p in points if isinstance(p["id"], int)]
    if not int_ids:
        return 0
    return max(int_ids) + 1

def datetime_to_millis(dt_str, tz_name):
    try:
        if '.' in dt_str:
            dt = datetime.strptime(dt_str, "%m-%d-%Y %H:%M:%S.%f")
        else:
            dt = datetime.strptime(dt_str, "%m-%d-%Y %H:%M:%S")
    except ValueError:
        return None
    tz = ZoneInfo(tz_name)
    dt = dt.replace(tzinfo=tz)
    return int(dt.timestamp() * 1000)

def current_millis():
    return int(datetime.now(tz=timezone.utc).timestamp() * 1000)

def add_point(collection, pid, vector, text, timestamp_ms):
    payload = {"text": text, "source": "qdredit", "timestamp": timestamp_ms}
    data = {"points": [{"id": pid, "vector": vector, "payload": payload}]}
    qdrant_request(f"/collections/{collection}/points", method="PUT", data=data)
    invalidate_points_cache(collection)
    print(f"{COLOR_BRIGHT_WHITE}Added point with ID: {COLOR_BOLD_BRIGHT_LIME}{pid}{COLOR_RESET}")

