                sys.exit(1)
            if not lines:
                print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} No input provided", file=sys.stderr)
                sys.exit(1)
            text_content = lines.rstrip('\n')

        print(f"{colorize('Generating embedding from', COLOR_BRIGHT_WHITE)} {COLOR_ICY_BLUE}{args.embedding_url}{COLOR_RESET} ...", file=sys.stderr)
        vector = get_embedding(text_content, args.embedding_url)
        if vector is None:
            print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} Failed to get embedding", file=sys.stderr)
            sys.exit(1)

        # ID handling (with integer conversion)
        if args.id == "auto":
            pid = get_next_integer_id(collection)
        else:
            if isinstance(args.id, str) and args.id.isdigit():
                pid = int(args.id)
            else:
                pid = args.id

        # Timestamp handling
        if args.timestamp == "auto":
            ts = current_millis()
        else:
            ts = datetime_to_millis(args.timestamp, TIMEZONE)
            if ts is None:
                print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} Invalid timestamp format. Use 'mm-dd-yyyy HH:MM:SS' or 'mm-dd-yyyy HH:MM:SS.sss'", file=sys.stderr)
                sys.exit(1)

        add_point(collection, pid, vector, text_content, ts)
    else:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} No action specified. Use -count, -list, -print, -fileprint, -fileadd, \n-consolidate, -delete, -stripdate, or -add.", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
