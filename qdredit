def consolidate_integer_points(collection):
        """
        Re‑index all integer points to a contiguous range 0..N-1.
        Only deletes old IDs that are greater than or equal to N (outside the new range).
        Asks for confirmation and verifies all new points exist before deleting.
        """
        points = get_all_points_with_vectors(collection)
        integer_points = [p for p in points if isinstance(p["id"], int)]
        if not integer_points:
            print(f"{colorize('Info:', COLOR_BRIGHT_WHITE)} No integer points to consolidate.")
            return False
    
        integer_points.sort(key=lambda p: p["id"])
        old_ids = [p["id"] for p in integer_points]
        min_id = min(old_ids)
        max_id = max(old_ids)
        n = len(integer_points)
        expected_max = n - 1
    
        # Already contiguous and start at 0? Exit.
        if min_id == 0 and max_id == expected_max and (max_id - min_id + 1) == n:
            print(f"{colorize('Info:', COLOR_BRIGHT_WHITE)} Integer points are already contiguous from 0 to {expected_max}. No consolidation needed.")
            return True
    
        # Create mapping from old ID to new ID
        new_id_map = {old: new for new, old in enumerate(old_ids)}
    
        # Show ranges and warn
        print(f"\n{colorize('Integer points found:', COLOR_BRIGHT_WHITE)} {COLOR_BOLD_BRIGHT_LIME}{n}{COLOR_RESET}")
        print(f"{colorize('Current ID range:', COLOR_BRIGHT_WHITE)} {COLOR_BOLD_BRIGHT_LIME}{min_id} {COLOR_BRIGHT_WHITE}– {COLOR_BOLD_BRIGHT_LIME}{max_id}{COLOR_RESET}")
        print(f"{colorize('New ID range after consolidation:', COLOR_BRIGHT_WHITE)} {COLOR_BOLD_BRIGHT_LIME}0 {COLOR_BRIGHT_WHITE}– {COLOR_BOLD_BRIGHT_LIME}{expected_max}{COLOR_RESET}")
        print()
        print(f"{colorize('WARNING:', COLOR_BOLD_BRICK_RED)} If this operation is interrupted or fails, you could lose all your data.")
        print(f"{colorize('You can always say no and back up your whole collection with:', COLOR_BRIGHT_WHITE)}")
        print(f"  {colorize('qdredit -fileprint all', COLOR_BOLD_BRIGHT_LIME)}")
        confirm = input(f"{colorize('Proceed with consolidation? (y/n): ', COLOR_BRIGHT_WHITE)}").strip().lower()
        if confirm != 'y':
            print("Cancelled.")
            return False
    
        # Build clean new points
        new_points = []
        for p in integer_points:
            new_points.append({
                "id": new_id_map[p["id"]],
                "vector": p["vector"],
                "payload": p["payload"]
            })
    
        # Upsert new points (this overwrites overlapping old IDs)
        batch_size = 100
        total = len(new_points)
        for i in range(0, total, batch_size):
            batch = new_points[i:i+batch_size]
            data = {"points": batch}
            qdrant_request(f"/collections/{collection}/points", method="PUT", data=data)
            print(f"Uploaded batch {i//batch_size + 1}/{(total-1)//batch_size + 1}")
    
        # Safety: verify that ALL new points exist
        missing = [new_id for new_id in range(n) if not point_exists(collection, new_id)]
        if missing:
            print(f"{colorize('ERROR:', COLOR_BOLD_BRICK_RED)} New points missing: {missing[:10]}... Aborting delete phase.")
            return False
    
        # Delete only old IDs that are >= n (outside the new contiguous range)
        ids_to_delete = [old for old in old_ids if old >= n]
        if ids_to_delete:
            print(f"{colorize('Deleting old IDs outside new range:', COLOR_BRIGHT_WHITE)} {min(ids_to_delete)}–{max(ids_to_delete)} (count {len(ids_to_delete)})")
            for i in range(0, len(ids_to_delete), batch_size):
                batch = ids_to_delete[i:i+batch_size]
                data = {"points": batch}
                qdrant_request(f"/collections/{collection}/points/delete", method="POST", data=data)
                print(f"Deleted batch {i//batch_size + 1}/{(len(ids_to_delete)-1)//batch_size + 1}")
        else:
            print(f"{colorize('Info:', COLOR_BRIGHT_WHITE)} No old IDs outside the new range – nothing to delete.")
    
        print(f"{colorize('Consolidation complete.', COLOR_BOLD_BRIGHT_LIME)} Integer points now contiguous 0..{n-1}.")
        invalidate_points_cache(collection)
        return True

def print_by_date(collection, date_str):
    try:
        month, day, year = map(int, date_str.split('-'))
    except:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} Invalid date format (use mm-dd-yyyy)", file=sys.stderr)
        return
    tz = ZoneInfo(TIMEZONE)
    dt = datetime(year, month, day, 0, 0, 0, tzinfo=tz)
    start_utc = int(dt.astimezone(timezone.utc).timestamp() * 1000)
    end_utc = int((dt + timedelta(days=1)).astimezone(timezone.utc).timestamp() * 1000)
    points = get_all_points(collection)
    found = False
    for p in points:
        ts = p["payload"].get("timestamp")
        if ts is not None and start_utc <= ts < end_utc:
            if isinstance(p["id"], int):
                print_point(p)
            else:
                print_uuid_point(p)
            found = True
    if not found:
        print(f"No points found for {date_str}")

