        new_payload["text"] = new_text
        if update_point_payload(collection, uuid, new_payload):
            print(f"{COLOR_BOLD_INDIGO_WHITE}Updated UUID {COLOR_BOLD_HOT_MAGENTA}{uuid}{COLOR_RESET}")
        else:
            print(f"{COLOR_BOLD_INDIGO_WHITE}Failed to update UUID {COLOR_BOLD_HOT_MAGENTA}{uuid}{COLOR_RESET}")
    print("Done.")

