def stripdate_by_uuid_range(collection, start_idx, end_idx, dry_run=False):
    uuid_pairs = get_sorted_uuid_pairs(collection)
    if not uuid_pairs:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} No UUID points exist", file=sys.stderr)
        sys.exit(1)
    if start_idx == end_idx:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} Invalid range: start and end indices must be different (use single uuid<index> for one point)", file=sys.stderr)
        return
    if start_idx >= len(uuid_pairs) or end_idx >= len(uuid_pairs):
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} UUID index range {start_idx}-{end_idx} out of range (max {len(uuid_pairs)-1})", file=sys.stderr)
        return
    count = end_idx - start_idx + 1
    print(f"\n{COLOR_BOLD_INDIGO_WHITE}Will process {count} UUID points (indices {start_idx} to {end_idx}).{COLOR_RESET}")
    if dry_run:
        print("Dry run – no changes will be made.")
    confirm = input("Proceed? (y/n) ").strip().lower()
