# ============================ FUNCTIONS ==============================
def should_use_color():
    return sys.stdout.isatty()

COLOR_ENABLED = True

def colorize(text, color_code):
    if COLOR_ENABLED:
        return f"{color_code}{text}{COLOR_RESET}"
    return text

def qdrant_request(endpoint, method="GET", data=None):
    url = f"{QD_URL}{endpoint}"
    headers = {"Content-Type": "application/json"}
    try:
        if method == "GET":
            resp = requests.get(url, headers=headers)
        elif method == "POST":
            resp = requests.post(url, headers=headers, json=data)
        elif method == "PUT":
            resp = requests.put(url, headers=headers, json=data)
        elif method == "DELETE":
            resp = requests.delete(url, headers=headers)
        resp.raise_for_status()
        return resp.json()
    except Exception as e:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} {e}", file=sys.stderr)
        sys.exit(1)

def get_collection_info(collection):
    return qdrant_request(f"/collections/{collection}")

def get_collection_config(collection):
        """Return (vector_size, distance) for the collection's default vector."""
        info = get_collection_info(collection)
        vectors_config = info.get("result", {}).get("config", {}).get("params", {}).get("vectors", {})
        # If the collection uses a single vector config (dictionary with size and distance)
        if isinstance(vectors_config, dict) and "size" in vectors_config and "distance" in vectors_config:
            return vectors_config["size"], vectors_config["distance"]
        # If there are named vectors (e.g., {"text": {"size": 384, "distance": "Cosine"}})
        # take the first one (most common case)
        if isinstance(vectors_config, dict):
            for v in vectors_config.values():
                if isinstance(v, dict) and "size" in v and "distance" in v:
                    return v["size"], v["distance"]
        raise ValueError("Could not determine vector config from collection info")

def point_exists(collection, pid):
    """Return True if the point exists, False otherwise (including 404)."""
    if isinstance(pid, int) and pid < 0:
        return False
    url = f"{QD_URL}/collections/{collection}/points/{pid}"
    try:
        resp = requests.get(url, headers={"Content-Type": "application/json"})
        if resp.status_code == 404:
            return False
        resp.raise_for_status()
        data = resp.json()
        return "result" in data and data["result"] is not None
    except requests.exceptions.RequestException:
        return False

def get_max_integer_id(collection, max_possible=10**9):
    """
    Return the largest existing integer point ID, or -1 if none exist.
    Optimized for the common case where integer IDs are consolidated 0..N-1.
    """
    total_count = get_collection_info(collection).get("result", {}).get("points_count", 0)
    if total_count == 0:
        return -1

    uuid_pairs = get_sorted_uuid_pairs(collection)
    uuid_count = len(uuid_pairs)
    integer_count = total_count - uuid_count

    if integer_count > 0:
        candidate = integer_count - 1
        if point_exists(collection, candidate):
            return candidate

    # Fall back to binary search
    low = -1
    probe = 0
    while probe <= max_possible:
        if point_exists(collection, probe):
            low = probe
            break
        if probe == 0:
            probe = 1
        else:
            probe *= 2
    if low == -1:
        return -1

    high = low * 2
    if high == 0:
        high = 1
    while high <= max_possible and point_exists(collection, high):
        high *= 2
        if high > max_possible:
            high = max_possible
            break

    while low < high:
        mid = (low + high + 1) // 2
        if point_exists(collection, mid):
            low = mid
        else:
            high = mid - 1

    return low

def fetch_point_text(collection, pid):
    resp = qdrant_request(f"/collections/{collection}/points/{pid}")
    if "result" in resp and resp["result"]:
        return resp["result"]["payload"].get("text", "")
    return ""

def get_all_points(collection, force_refresh=False):
    """
    Retrieve all points using cursor-based pagination, with caching.
    Set force_refresh=True to ignore cache (e.g., after modifications).
    """
    if not force_refresh and collection in _points_cache:
        return _points_cache[collection]

    points = []
    limit = 100
    offset = None

    while True:
        data = {"limit": limit}
        if offset is not None:
            data["offset"] = offset

        resp = qdrant_request(
            f"/collections/{collection}/points/scroll",
            method="POST",
            data=data
        )
        result = resp.get("result", {})
        page_points = result.get("points", [])
        points.extend(page_points)

        offset = result.get("next_page_offset")
        if not offset:
            break

    _points_cache[collection] = points
    return points

def get_all_points_with_vectors(collection):
    """
    Retrieve all points including their vector data.
    Uses paginated scroll with 'with_vector': True.
    Does NOT cache results to avoid memory bloat.
    """
    points = []
    limit = 100
    offset = None

    while True:
        data = {"limit": limit, "with_vector": True}
        if offset is not None:
            data["offset"] = offset

        resp = qdrant_request(
            f"/collections/{collection}/points/scroll",
            method="POST",
            data=data
        )
        result = resp.get("result", {})
        page_points = result.get("points", [])
        points.extend(page_points)

        offset = result.get("next_page_offset")
        if not offset:
            break

    return points
    
def compact_ranges(ids):
    if not ids:
        return "none"
    ids = sorted(ids)
    ranges = []
    start = ids[0]
    prev = ids[0]
    for i in ids[1:]:
        if i - prev > 1:
            if start == prev:
                ranges.append(str(start))
            else:
                ranges.append(f"{start}-{prev}")
            start = i
        prev = i
    if start == prev:
        ranges.append(str(start))
    else:
        ranges.append(f"{start}-{prev}")
    return ",".join(ranges)

def get_sorted_uuid_pairs(collection):
    points = get_all_points(collection)
    uuids = []
    for p in points:
        pid = p["id"]
        if isinstance(pid, str) and re.match(r'^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$', pid):
            ts = p["payload"].get("timestamp", 0)
            uuids.append((ts, pid))
    uuids.sort(key=lambda x: (x[0], x[1])) # sort by time, then UUID for                                                   # determinism
    return uuids

def invalidate_points_cache(collection):
    """Invalidate cached points for a collection after changes."""
    _points_cache.pop(collection, None)
    _MAX_ID_CACHE.pop(collection, None)

def format_timestamp(ts_ms):
    secs = round(ts_ms / 1000.0)
    dt = datetime.fromtimestamp(secs, tz=timezone.utc).astimezone(ZoneInfo(TIMEZONE))
    return dt.strftime("%x %I:%M:%S %p")

def visible_len(s):
    """Return visible length of string after stripping ANSI escape sequences."""
    return len(re.sub(r'\033\[[0-9;]*m', '', s))

def fileprint_points(collection, point_ids, output_file="qdrantpoints"):
    converted_ids = []
    for pid in point_ids:
        if pid.isdigit():
            converted_ids.append(int(pid))
        else:
            converted_ids.append(pid)

    resp = qdrant_request(f"/collections/{collection}/points", method="POST", data={"ids": converted_ids})
    points = resp.get("result", [])
    if not points:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} No points found for the given IDs")
        return False
    with open(output_file, 'w') as f:
        json.dump(points, f, indent=2)
    print(f"Saved {len(points)} points to {output_file}")
    return True

def fileprint_by_range(collection, start, end, output_file="qdrantpoints"):
    points = get_all_points(collection)
    filtered = [p for p in points if isinstance(p["id"], int) and start <= p["id"] <= end]
    if not filtered:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} No points found in range {start}-{end}")
        return False
    with open(output_file, 'w') as f:
        json.dump(filtered, f, indent=2)
    print(f"Saved {len(filtered)} points to {output_file}")
    return True

def fileprint_by_date(collection, date_str, output_file="qdrantpoints"):
    try:
        month, day, year = map(int, date_str.split('-'))
    except:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} Invalid date format (use mm-dd-yyyy)")
        return False
    tz = ZoneInfo(TIMEZONE)
    dt = datetime(year, month, day, 0, 0, 0, tzinfo=tz)
    start_utc = int(dt.astimezone(timezone.utc).timestamp() * 1000)
    end_utc = int((dt + timedelta(days=1)).astimezone(timezone.utc).timestamp() * 1000)
    points = get_all_points(collection)
    filtered = [p for p in points if p["payload"].get("timestamp", 0) and start_utc <= p["payload"]["timestamp"] < end_utc]
    if not filtered:
        print(f"No points found for {date_str}")
        return False
    with open(output_file, 'w') as f:
        json.dump(filtered, f, indent=2)
    print(f"Saved {len(filtered)} points to {output_file}")
    return True

def fileprint_by_uuid_index(collection, idx, output_file="qdrantpoints"):
    uuid_pairs = get_sorted_uuid_pairs(collection)
    if not uuid_pairs:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} No UUID points exist")
        return False
    if idx >= len(uuid_pairs):
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} UUID index {idx} out of range (max {len(uuid_pairs)-1})")
        return False
    uuid = uuid_pairs[idx][1]
    resp = qdrant_request(f"/collections/{collection}/points/{uuid}")
    if "result" not in resp or not resp["result"]:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} Point {uuid} not found")
        return False
    with open(output_file, 'w') as f:
        json.dump([resp["result"]], f, indent=2)
    print(f"Saved 1 point to {output_file}")
    return True

def fileprint_by_uuid_range(collection, start_idx, end_idx, output_file="qdrantpoints"):
    uuid_pairs = get_sorted_uuid_pairs(collection)
    if not uuid_pairs:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} No UUID points exist")
        return False
    if start_idx >= len(uuid_pairs) or end_idx >= len(uuid_pairs):
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} UUID index range {start_idx}-{end_idx} out of range (max {len(uuid_pairs)-1})")
        return False
    uuids = [uuid_pairs[i][1] for i in range(start_idx, end_idx+1)]
    resp = qdrant_request(f"/collections/{collection}/points", method="POST", data={"ids": uuids})
    points = resp.get("result", [])
    if not points:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} No points found")
        return False
    with open(output_file, 'w') as f:
        json.dump(points, f, indent=2)
    print(f"Saved {len(points)} points to {output_file}")
    return True

def fileprint_all(collection, output_file="qdrantpoints"):
    """
    Fetch all points (integer and UUID) including vectors, clean them,
    and write a JSON object with metadata and points to a single file.
    """
    points = get_all_points_with_vectors(collection)
    if not points:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} No points found in collection")
        return False

    # Clean each point: keep only id, vector, payload
    cleaned_points = []
    for p in points:
        pid = p["id"]
        if isinstance(pid, str) and pid.isdigit():
            pid = int(pid)
        cleaned_points.append({
            "id": pid,
            "vector": p["vector"],
            "payload": p["payload"]
        })

    # Get collection metadata
    try:
        vector_size, distance = get_collection_config(collection)
    except Exception as e:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} Could not read collection config: {e}")
        return False

    # Build the full export object
    export_data = {
        "metadata": {
            "vector_size": vector_size,
            "distance": distance
        },
        "points": cleaned_points
    }

    with open(output_file, 'w') as f:
        json.dump(export_data, f, indent=2)

    print(f"Saved {len(cleaned_points)} points with metadata (size={vector_size}, distance={distance}) to {output_file}")
    return True

def ensure_collection_exists(collection, vector_size, distance="Cosine"):
    """Create collection if it doesn't exist, using given vector size and distance."""
    try:
        get_collection_info(collection)
        # Collection exists – nothing to do
    except:
        # Collection does not exist – create it
        data = {"vectors": {"size": vector_size, "distance": distance}}
        qdrant_request(f"/collections/{collection}", method="PUT", data=data)
        print(f"{colorize('Created collection:', COLOR_BRIGHT_WHITE)} {collection}")

def fileadd_from_file(collection, input_file="qdrantpoints"):
    """
    Read points and metadata from a JSON file (created by -fileprint all)
    and upsert them into Qdrant. Creates the collection if missing.
    """
    if not os.path.exists(input_file):
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} File {input_file} not found")
        return False

    try:
        with open(input_file, 'r') as f:
            data = json.load(f)
    except Exception as e:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} Failed to parse JSON: {e}")
        return False

    # Handle both old format (array of points) and new format (object with points)
    if isinstance(data, list):
        # Legacy file: just points array
        points = data
        # Try to read metadata from companion file if it exists (optional compatibility)
        meta_file = input_file + ".meta.json"
        if os.path.exists(meta_file):
            try:
                with open(meta_file, 'r') as mf:
                    meta = json.load(mf)
                vector_size = meta.get("vector_size")
                distance = meta.get("distance", "Cosine")
            except:
                vector_size = None
                distance = "Cosine"
        else:
            # No metadata: get vector size from first point, prompt for distance
            if not points:
                print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} Empty points file")
                return False
            first_vector = points[0].get("vector")
            if not first_vector:
                print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} First point has no 'vector' field")
                return False
            vector_size = len(first_vector)
            print(f"{colorize('No metadata found. Detected vector size:', COLOR_BRIGHT_WHITE)} {vector_size}")
            distance = input(f"Enter distance metric [Cosine/Euclid/Dot] (default: Cosine): ").strip()
            if distance not in ["Cosine", "Euclid", "Dot"]:
                distance = "Cosine"
    else:
        # New format: object with metadata and points
        metadata = data.get("metadata", {})
        vector_size = metadata.get("vector_size")
        distance = metadata.get("distance", "Cosine")
        points = data.get("points", [])
        if not points:
            print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} No points in file")
            return False
        if not vector_size:
            # Fallback: detect from first point
            first_vector = points[0].get("vector")
            if not first_vector:
                print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} First point has no 'vector' field")
                return False
            vector_size = len(first_vector)

    # Sanitize points (already cleaned, but re‑sanitize to be safe)
    cleaned_points = []
    for point in points:
        pid = point.get("id")
        if pid is None:
            continue
        if isinstance(pid, str) and pid.isdigit():
            pid = int(pid)
        if "vector" not in point or "payload" not in point:
            continue
        cleaned_points.append({
            "id": pid,
            "vector": point["vector"],
            "payload": point["payload"]
        })

    if not cleaned_points:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} No valid points to add")
        return False

    # Ensure collection exists (create if missing) – silent check
    resp = requests.get(f"{QD_URL}/collections/{collection}", headers={"Content-Type": "application/json"})
    if resp.status_code == 404:
        data = {"vectors": {"size": vector_size, "distance": distance}}
        qdrant_request(f"/collections/{collection}", method="PUT", data=data)
        print(f"{colorize('Created collection:', COLOR_BRIGHT_WHITE)} {collection} (size={vector_size}, distance={distance})")
    elif resp.status_code != 200:
        print(f"{colorize('Error:', COLOR_BOLD_BRICK_RED)} Failed to check collection: {resp.status_code}", file=sys.stderr)
        return False

    # Upload in batches
    batch_size = 100
    total = len(cleaned_points)
    for i in range(0, total, batch_size):
        batch = cleaned_points[i:i+batch_size]
        data = {"points": batch}
        qdrant_request(f"/collections/{collection}/points", method="PUT", data=data)
        print(f"Uploaded batch {i//batch_size + 1}/{(total-1)//batch_size + 1}")

    print(f"Successfully added {total} points to collection '{collection}'")
    invalidate_points_cache(collection)
    return True

