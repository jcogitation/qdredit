        old_text = resp["result"]["payload"]["text"]
        new_text = strip_date_from_text(old_text)
        if old_text == new_text:
            print(f"{COLOR_BOLD_INDIGO_WHITE}UUID {COLOR_BOLD_HOT_MAGENTA}{uuid}{COLOR_BOLD_INDIGO_WHITE} already has no leading date, skipping{COLOR_RESET}")
            continue
